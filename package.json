{
  "name": "neon-protocol",
  "version": "5.1.0",
  "description": "NEON PROTOCOL ⌬ - Rush Platformer with Boss & Power-ups",
  "main": "src/electron/main.js",
  "author": "Kyra ⌬",
  "license": "MIT",
  "scripts": {
    "start": "electron src/electron/main.js",
    "dev": "npm install && npm run start",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --x64",
    "build:linux": "electron-builder --linux --x64"
  },
  "keywords": ["game", "platformer", "electron", "windows"],
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.kyra.neon-protocol",
    "productName": "NEON PROTOCOL",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "src/electron/**/*",
      "index.html",
      "game.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.ico"
    }
  }
}
